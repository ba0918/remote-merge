#!/bin/sh
# pre-push hook: unit tests + integration tests
set -e

echo "pre-push: unit tests..."
cargo test --lib --all-features
if [ $? -ne 0 ]; then
    echo "ERROR: unit tests failed. Push aborted."
    exit 1
fi

echo "pre-push: integration tests..."
cargo test --test '*' --all-features
if [ $? -ne 0 ]; then
    echo "ERROR: integration tests failed. Push aborted."
    exit 1
fi

echo "pre-push: OK"
